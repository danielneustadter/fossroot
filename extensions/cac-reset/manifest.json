{
  "manifest_version": 3,
  "name": "FossRoot CAC Reset",
  "version": "0.1.0",
  "description": "Fixes the 'I forgot to plug in my CAC, now I have to restart the whole browser' problem. Talks only to the local FossRoot Agent; nothing leaves your machine.",
  "key": "",
  "permissions": ["nativeMessaging", "activeTab", "webRequest", "storage"],
  "host_permissions": ["*://*.mil/*"],
  "background": { "service_worker": "background.js" },
  "action": {
    "default_popup": "popup.html",
    "default_title": "FossRoot CAC Reset"
  }
}
